---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nadia Ujovich — Desarrolladora, Tech Speaker & WTM Ambassador',
  description = 'Portfolio de Nadia Ujovich, desarrolladora de software full-stack, tech speaker, Women Techmakers Ambassador en Madrid y co-fundadora de Mermelada Tech.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://nadiaujovich.dev');
const ogImage = 'https://nadiaujovich.dev/nadia.jpeg';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Nadia Ujovich" />
    <meta name="keywords" content="Nadia Ujovich, desarrolladora software, tech speaker, Women Techmakers Ambassador, Mermelada Tech, Madrid, full-stack developer, Astro, React, seguridad web" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (LinkedIn, Facebook, WhatsApp) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Nadia Ujovich — Desarrolladora & Tech Speaker" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Nadia Ujovich" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@nujovich" />
    <meta name="twitter:creator" content="@nujovich" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data — Google usa esto para el Knowledge Panel -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Nadia Ujovich",
        "url": "https://nadiaujovich.dev",
        "image": "https://nadiaujovich.dev/nadia.jpeg",
        "email": "nujovich@gmail.com",
        "jobTitle": "Desarrolladora de Software & Tech Speaker",
        "description": "Desarrolladora full-stack, Women Techmakers Ambassador en Madrid y co-fundadora de Mermelada Tech.",
        "sameAs": [
          "https://linkedin.com/in/nadiaujovich",
          "https://github.com/nujovich",
          "https://twitter.com/nujovich",
          "https://linktr.ee/mermeladatech",
          "https://www.youtube.com/@mermeladatech"
        ],
        "knowsAbout": ["JavaScript", "TypeScript", "React", "Astro", "Seguridad Web", "Node.js"],
        "memberOf": {
          "@type": "Organization",
          "name": "Women Techmakers",
          "url": "https://wtmgdgmadrid.github.io/"
        },
        "founder": {
          "@type": "Organization",
          "name": "Mermelada Tech",
          "url": "https://linktr.ee/mermeladatech"
        }
      }
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" />
    <meta name="theme-color" content="#0f172a" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>

  <body class="bg-slate-950 text-slate-100 font-[Inter,sans-serif] antialiased">
    <!-- Nav -->
    <header
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
      transition:persist
    >
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold gradient-text hover:opacity-80 transition-opacity">
          Nadia Ujovich
        </a>
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-300">
          <li><a href="#about"    class="hover:text-white transition-colors">Sobre mí</a></li>
          <li><a href="#skills"   class="hover:text-white transition-colors">Skills</a></li>
          <li><a href="#projects" class="hover:text-white transition-colors">Proyectos</a></li>
          <li><a href="#videos"   class="hover:text-white transition-colors">Videos</a></li>
          <li><a href="#contact"  class="hover:text-white transition-colors">Contacto</a></li>
        </ul>
        <button id="menu-toggle" class="md:hidden text-slate-300 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </nav>
      <div id="mobile-menu" class="hidden md:hidden glass border-t border-white/10">
        <ul class="flex flex-col gap-4 px-6 py-4 text-sm font-medium text-slate-300">
          <li><a href="#about"    class="hover:text-white transition-colors block py-1">Sobre mí</a></li>
          <li><a href="#skills"   class="hover:text-white transition-colors block py-1">Skills</a></li>
          <li><a href="#projects" class="hover:text-white transition-colors block py-1">Proyectos</a></li>
          <li><a href="#videos"   class="hover:text-white transition-colors block py-1">Videos</a></li>
          <li><a href="#contact"  class="hover:text-white transition-colors block py-1">Contacto</a></li>
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-white/10 py-10 text-center text-slate-500 text-sm">
      <p>© {new Date().getFullYear()} Nadia Ujovich — Hecho con <span class="text-brand-400">♥</span> en Astro</p>
    </footer>

    <script>
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          navbar?.classList.add('glass', 'shadow-lg');
        } else {
          navbar?.classList.remove('glass', 'shadow-lg');
        }
      });

      const toggle = document.getElementById('menu-toggle');
      const menu   = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
      menu?.querySelectorAll('a').forEach(a =>
        a.addEventListener('click', () => menu.classList.add('hidden'))
      );
    </script>
  </body>
</html>
