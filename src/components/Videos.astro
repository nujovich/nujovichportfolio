---
const videos = [
  {
    id: 'igHnQ52lGrg',
    title: 'Charla sobre Astro',
    description:
      'Mi última charla sobre Astro, el framework web moderno para construir sitios rápidos y orientados al contenido.',
    event: 'Charla Astro',
    tag: '🚀 Astro',
  },
  {
    id: 'bMdlBjKSQF4',
    title: 'Entrevista en Commit Conf 2024',
    description:
      'Entrevista en la Commit Conf 2024, una de las conferencias de desarrollo de software más importantes de España, celebrada en Madrid.',
    event: 'Commit Conf 2024',
    tag: '🎤 Conferencia',
  },
  {
    id: 'BD930rVGQc0',
    title: 'Seguridad Web',
    description:
      'Charla sobre los principales riesgos de seguridad web según OWASP Top 10, con ejemplos prácticos y cómo proteger tus aplicaciones.',
    event: 'AccelOne Tech Talk',
    tag: '🔒 Seguridad',
  },
  {
    id: 'UcfMiU1Nk6E',
    title: 'Bienvenidos a Mermelada Tech',
    description:
      'Video de presentación de la comunidad Mermelada Tech, el espacio inclusivo para mujeres y personas diversas en tecnología.',
    event: 'Mermelada Tech',
    tag: '🍓 Comunidad',
  },
  {
    id: 'eBJNT8KV0ps',
    title: 'Mermelada Tech en DevDay4Women',
    description:
      'Presentación de la comunidad Mermelada Tech en el Dev Day 4 Women, evento dedicado a visibilizar mujeres en tecnología.',
    event: 'DevDay4Women',
    tag: '🌸 Evento',
  },
  {
    id: 'hQdEi54-pvw',
    title: "Meetup 2024: Chicas en comunidades tech",
    description:
      'Meetup de Mermelada Tech en 2024, con debate y reflexiones sobre la participación de mujeres en comunidades tecnológicas.',
    event: 'Mermelada Tech Meetup',
    tag: '🤝 Meetup',
  },
];
---

<section id="videos" class="py-32 px-6 bg-slate-900/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-brand-400 text-sm font-semibold tracking-widest uppercase mb-3">YouTube</p>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white">
        Charlas & <span class="gradient-text">Videos</span>
      </h2>
      <p class="text-slate-400 mt-4 max-w-xl mx-auto">
        Mis apariciones en conferencias, comunidades y canales de tecnología.
      </p>
    </div>

    <!-- Featured video -->
    <div class="mb-10 glass rounded-2xl overflow-hidden card-hover">
      <div class="aspect-video w-full">
        <iframe
          class="w-full h-full"
          src={`https://www.youtube.com/embed/${videos[0].id}`}
          title={videos[0].title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div class="p-6">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-semibold text-brand-400 bg-brand-400/10 border border-brand-400/20 rounded-full px-3 py-1">
            Destacado
          </span>
          <span class="text-xs text-slate-500">{videos[0].tag}</span>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">{videos[0].title}</h3>
        <p class="text-slate-400 text-sm">{videos[0].description}</p>
      </div>
    </div>

    <!-- Grid of other videos -->
    <div class="grid md:grid-cols-2 gap-6">
      {videos.slice(1).map(({ id, title, description, tag }) => (
        <div class="glass rounded-2xl overflow-hidden card-hover">
          <div class="aspect-video w-full">
            <iframe
              class="w-full h-full"
              src={`https://www.youtube.com/embed/${id}`}
              title={title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="p-5">
            <span class="text-xs text-slate-500 block mb-2">{tag}</span>
            <h3 class="text-base font-bold text-white mb-2">{title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
