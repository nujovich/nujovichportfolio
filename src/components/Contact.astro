<section id="contact" class="py-32 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-brand-400 text-sm font-semibold tracking-widest uppercase mb-3">Contacto</p>
    <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">
      ¡Hablemos! <span class="gradient-text">👋</span>
    </h2>
    <p class="text-slate-400 text-lg mb-12 max-w-2xl mx-auto leading-relaxed">
      ¿Tienes un proyecto, quieres que dé una charla en tu evento o simplemente quieres conectar?
      Escríbeme y te respondo lo antes posible.
    </p>

    <!-- CTA Button -->
    <a
      href="mailto:hola@nadiaujovich.com"
      class="inline-flex items-center gap-3 px-10 py-5 bg-brand-500 hover:bg-brand-600 text-white font-bold text-lg rounded-2xl transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-brand-500/30 mb-16"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      hola@nadiaujovich.com
    </a>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-6">
      {socials.map(({ name, href, icon, color }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class={`glass w-12 h-12 rounded-xl flex items-center justify-center text-slate-400 ${color} transition-all duration-300 hover:scale-110 hover:border-white/20`}
          aria-label={name}
          set:html={icon}
        />
      ))}
    </div>
  </div>
</section>
